# 로컬 테스트용 예시 파일. 실제 파일명은 secrets.toml 로 저장하세요.
# Streamlit Cloud에 올릴 때는 대시보드의 Secrets 메뉴에 같은 내용을 붙여넣습니다.

[sheet]
id = "구글시트_문서ID_여기에"

[smart_space]
# 스마트돌봄스페이스 페이지용 외부 시트 (각 시트에 서비스 계정을 '편집자'로 공유해야 함)
faq_sheet_id = "FAQ_구글시트_문서ID"        # "스마트돌봄스페이스 FAQ" (백정은)
space_sheet_id = "관리대장_구글시트_문서ID"  # "스마트돌봄스페이스 관련 문제 및 돌봄로봇 관리" (한벼리)

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "streamlit-bot@your-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
